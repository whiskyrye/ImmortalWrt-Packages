#!/bin/sh
# ubus: luci.bandix_plus — 代理到本机 bandix-plus HTTP API（见 bandix-plus/src/api.rs）
. /usr/share/libubox/jshn.sh

bplus_base() {
	local p
	p="$(uci -q get bandix_plus.general.port)"
	[ -z "$p" ] && p="8787"
	printf 'http://127.0.0.1:%s' "$p"
}

bplus_get() {
	curl -s -g --connect-timeout 2 --max-time 15 -X GET "$1"
}

bplus_put_json() {
	curl -s -g --connect-timeout 2 --max-time 20 -X PUT -H "Content-Type: application/json" -d "$1" "$2"
}

bplus_post_json() {
	curl -s -g --connect-timeout 2 --max-time 20 -X POST -H "Content-Type: application/json" -d "$1" "$2"
}

bplus_delete() {
	curl -s -g --connect-timeout 2 --max-time 20 -X DELETE "$1"
}

bplus_delete_json() {
	curl -s -g --connect-timeout 2 --max-time 20 -X DELETE -H "Content-Type: application/json" -d "$1" "$2"
}

uripart() { printf %s "$1" | sed 's/+/%2B/g'; }

# LuCI rpc.declare(..., params: ['payload']) sends {"payload": <API JSON>} — curl must use inner body only.
bplus_unwrap_payload() {
	local raw="$1"
	local inner
	inner="$(echo "$raw" | jsonfilter -e '$.payload' 2>/dev/null)"
	if [ -n "$inner" ]; then
		printf '%s' "$inner"
	else
		printf '%s' "$raw"
	fi
}

# params: ['pair'] → {"pair": [ id, body ]}
bplus_unwrap_pair() {
	local raw="$1"
	local inner
	inner="$(echo "$raw" | jsonfilter -e '$.pair' 2>/dev/null)"
	if [ -n "$inner" ]; then
		printf '%s' "$inner"
	else
		printf '%s' "$raw"
	fi
}

case "$1" in
	list)
		json_init
		json_add_object "getHealth"
		json_close_object
		json_add_object "getSnapshot"
		json_close_object
		json_add_object "getOverview"
		json_add_string "period"
		json_close_object
		json_add_object "getDevices"
		json_add_string "iface"
		json_add_string "period"
		json_close_object
		json_add_object "getTrend"
		json_add_string "iface"
		json_add_string "mac"
		json_add_string "traffic_type"
		json_add_string "direction"
		json_close_object
		json_add_object "getHistogram"
		json_add_string "iface"
		json_add_string "mac"
		json_add_string "traffic_type"
		json_add_string "start_ms"
		json_add_string "end_ms"
		json_add_string "bucket"
		json_close_object
		json_add_object "getUsageRanking"
		json_add_string "iface"
		json_add_string "traffic_type"
		json_add_string "start_ms"
		json_add_string "end_ms"
		json_add_string "limit"
		json_close_object
		json_add_object "getPolicy"
		json_close_object
		json_add_object "getSchedules"
		json_close_object
		json_add_object "createSchedule"
		json_add_string "payload"
		json_close_object
		json_add_object "updateSchedule"
		json_add_string "pair"
		json_close_object
		json_add_object "deleteSchedule"
		json_add_string "id"
		json_close_object
		json_add_object "getIfaceLimits"
		json_close_object
		json_add_object "setIfaceLimit"
		json_add_string "payload"
		json_close_object
		json_add_object "deleteIfaceLimit"
		json_add_string "iface"
		json_close_object
		json_add_object "getGuestDefaults"
		json_close_object
		json_add_object "setGuestDefault"
		json_add_string "payload"
		json_close_object
		json_add_object "setGuestDefaultEnabled"
		json_add_string "payload"
		json_close_object
		json_add_object "deleteGuestDefault"
		json_add_string "iface"
		json_close_object
		json_add_object "getGuestWhitelist"
		json_close_object
		json_add_object "addGuestWhitelist"
		json_add_string "payload"
		json_close_object
		json_add_object "removeGuestWhitelist"
		json_add_string "payload"
		json_close_object
		json_add_object "setDeviceHostname"
		json_add_string "iface"
		json_add_string "mac"
		json_add_string "hostname"
		json_close_object
		json_add_object "getVersion"
		json_close_object
		json_add_object "getStatus"
		json_close_object
		json_add_object "restartService"
		json_close_object
		json_dump
		json_cleanup
		;;
	call)
		BASE="$(bplus_base)"
		case "$2" in
			getHealth) bplus_get "$BASE/api/health" ;;
			getSnapshot) bplus_get "$BASE/api/snapshot" ;;
			getOverview)
				input=""
				read -t 1 -r input || true
				period="${3:-}"
				if [ -n "$input" ]; then
					[ -z "$period" ] && period="$(echo "$input" | jsonfilter -e '$.period' 2>/dev/null)"
					[ -z "$period" ] && period="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
				fi
				if [ -n "$period" ]; then
					bplus_get "$BASE/api/overview?period=$(printf %s "$period" | sed 's/ /%20/g')"
				else
					bplus_get "$BASE/api/overview"
				fi
				;;
			getDevices)
				input=""
				read -t 1 -r input || true
				iface="${3:-}"; pperiod="${4:-}"
				if [ -n "$input" ]; then
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"
					[ -z "$pperiod" ] && pperiod="$(echo "$input" | jsonfilter -e '$.period' 2>/dev/null)"
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
					[ -z "$pperiod" ] && pperiod="$(echo "$input" | jsonfilter -e '$[1]' 2>/dev/null)"
				fi
				qs=""
				[ -n "$iface" ] && qs="${qs}iface=$(printf %s "$iface" | sed 's/ /%20/g')&"
				[ -n "$pperiod" ] && qs="${qs}period=$(printf %s "$pperiod" | sed 's/ /%20/g')&"
				qs="${qs#}"; qs="${qs%&}"
				[ -n "$qs" ] && bplus_get "$BASE/api/devices?$qs" || bplus_get "$BASE/api/devices"
				;;
			getTrend)
				input=""
				read -t 1 -r input || true
				iface="${3:-}"; mac="${4:-}"; ttype="${5:-}"; ddir="${6:-}"
				if [ -n "$input" ]; then
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
					[ -z "$mac" ] && mac="$(echo "$input" | jsonfilter -e '$.mac' 2>/dev/null)"
					[ -z "$mac" ] && mac="$(echo "$input" | jsonfilter -e '$[1]' 2>/dev/null)"
					[ -z "$ttype" ] && ttype="$(echo "$input" | jsonfilter -e '$.traffic_type' 2>/dev/null)"
					[ -z "$ttype" ] && ttype="$(echo "$input" | jsonfilter -e '$[2]' 2>/dev/null)"
					[ -z "$ddir" ] && ddir="$(echo "$input" | jsonfilter -e '$.direction' 2>/dev/null)"
					[ -z "$ddir" ] && ddir="$(echo "$input" | jsonfilter -e '$[3]' 2>/dev/null)"
				fi
				qs=""
				[ -n "$iface" ] && qs="iface=$(printf %s "$iface" | sed 's/ /%20/g')"
				[ -n "$mac" ] && qs="${qs}${qs:+&}mac=$(printf %s "$mac" | sed 's/ /%20/g')"
				[ -n "$ttype" ] && qs="${qs}${qs:+&}traffic_type=$(printf %s "$ttype" | sed 's/ /%20/g')"
				[ -n "$ddir" ] && qs="${qs}${qs:+&}direction=$(printf %s "$ddir" | sed 's/ /%20/g')"
				[ -n "$qs" ] && bplus_get "$BASE/api/trend?$qs" || bplus_get "$BASE/api/trend"
				;;
			getHistogram)
				input=""
				read -t 1 -r input || true
				iface="${3:-}"; mac="${4:-}"; ttype="${5:-}"; s_ms="${6:-}"; e_ms="${7:-}"; bucket="${8:-}"
				if [ -n "$input" ]; then
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
					[ -z "$mac" ] && mac="$(echo "$input" | jsonfilter -e '$.mac' 2>/dev/null)"
					[ -z "$ttype" ] && ttype="$(echo "$input" | jsonfilter -e '$.traffic_type' 2>/dev/null)"
					[ -z "$s_ms" ] && s_ms="$(echo "$input" | jsonfilter -e '$.start_ms' 2>/dev/null)"
					[ -z "$e_ms" ] && e_ms="$(echo "$input" | jsonfilter -e '$.end_ms' 2>/dev/null)"
					[ -z "$bucket" ] && bucket="$(echo "$input" | jsonfilter -e '$.bucket' 2>/dev/null)"
				fi
				qs=""
				[ -n "$iface" ] && qs="iface=$(printf %s "$iface" | sed 's/ /%20/g')"
				[ -n "$mac" ] && qs="${qs}${qs:+&}mac=$(printf %s "$mac" | sed 's/ /%20/g')"
				[ -n "$ttype" ] && qs="${qs}${qs:+&}traffic_type=$(printf %s "$ttype" | sed 's/ /%20/g')"
				[ -n "$s_ms" ] && qs="${qs}${qs:+&}start_ms=$s_ms"
				[ -n "$e_ms" ] && qs="${qs}${qs:+&}end_ms=$e_ms"
				[ -n "$bucket" ] && qs="${qs}${qs:+&}bucket=$bucket"
				[ -n "$qs" ] && bplus_get "$BASE/api/histogram?$qs" || bplus_get "$BASE/api/histogram"
				;;
			getUsageRanking)
				input=""
				read -t 1 -r input || true
				iface="${3:-}"; ttype="${4:-}"; s_ms="${5:-}"; e_ms="${6:-}"; lim="${7:-}"
				if [ -n "$input" ]; then
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"
					[ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
					[ -z "$ttype" ] && ttype="$(echo "$input" | jsonfilter -e '$.traffic_type' 2>/dev/null)"
					[ -z "$s_ms" ] && s_ms="$(echo "$input" | jsonfilter -e '$.start_ms' 2>/dev/null)"
					[ -z "$e_ms" ] && e_ms="$(echo "$input" | jsonfilter -e '$.end_ms' 2>/dev/null)"
					[ -z "$lim" ] && lim="$(echo "$input" | jsonfilter -e '$.limit' 2>/dev/null)"
				fi
				qs=""
				[ -n "$iface" ] && qs="iface=$(printf %s "$iface" | sed 's/ /%20/g')"
				[ -n "$ttype" ] && qs="${qs}${qs:+&}traffic_type=$(printf %s "$ttype" | sed 's/ /%20/g')"
				[ -n "$s_ms" ] && qs="${qs}${qs:+&}start_ms=$s_ms"
				[ -n "$e_ms" ] && qs="${qs}${qs:+&}end_ms=$e_ms"
				[ -n "$lim" ] && qs="${qs}${qs:+&}limit=$lim"
				[ -n "$qs" ] && bplus_get "$BASE/api/usage_ranking?$qs" || bplus_get "$BASE/api/usage_ranking"
				;;
			getPolicy) bplus_get "$BASE/api/policy" ;;
			getSchedules) bplus_get "$BASE/api/rate_limit/schedules" ;;
			createSchedule)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				[ -z "$js" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"createSchedule: empty body"}'
					exit 0
				}
				bplus_post_json "$js" "$BASE/api/rate_limit/schedules"
				;;
			updateSchedule)
				input=""
				read -r -t 5 input || true
				pair="${3:-}"
				if [ -n "$input" ]; then
					pair="$(bplus_unwrap_pair "$input")"
				elif [ -n "$pair" ]; then
					pair="$(bplus_unwrap_pair "$pair")"
				fi
				rid="$(echo "$pair" | jsonfilter -e '$[0]' 2>/dev/null)"
				body="$(echo "$pair" | jsonfilter -e '$[1]' 2>/dev/null)"
				[ -n "$rid" ] && [ -n "$body" ] && bplus_put_json "$body" "$BASE/api/rate_limit/schedules/$(uripart "$rid")" && exit 0
				printf '%s' '{"ok":false,"data":null,"error":"updateSchedule: 参数为 JSON 数组 [id, 体对象]"}'
				;;
			deleteSchedule)
				input=""
				read -r -t 5 input || true
				rid="${3:-}"
				if [ -z "$rid" ] && [ -n "$input" ]; then
					rid="$(echo "$input" | jsonfilter -e '$.id' 2>/dev/null)"
					[ -z "$rid" ] && rid="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
				fi
				bplus_delete "$BASE/api/rate_limit/schedules/$(uripart "$rid")"
				;;
			getIfaceLimits) bplus_get "$BASE/api/rate_limit/iface_limits" ;;
			setIfaceLimit)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				[ -z "$js" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"setIfaceLimit: empty body"}'
					exit 0
				}
				bplus_post_json "$js" "$BASE/api/rate_limit/iface_limits"
				;;
			deleteIfaceLimit)
				iface="${3:-}"
				[ -z "$iface" ] && { read -t 1 -r input || true; iface="$(echo "$input" | jsonfilter -e '$[0]')"; [ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"; }
				bplus_delete "$BASE/api/rate_limit/iface_limits/$(uripart "$iface")"
				;;
			getGuestDefaults) bplus_get "$BASE/api/rate_limit/guest_defaults" ;;
			setGuestDefault)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				[ -z "$js" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"setGuestDefault: empty body"}'
					exit 0
				}
				bplus_post_json "$js" "$BASE/api/rate_limit/guest_defaults"
				;;
			setGuestDefaultEnabled)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				iface="$(echo "$js" | jsonfilter -e '$.iface' 2>/dev/null)"
				enabled="$(echo "$js" | jsonfilter -e '$.enabled' 2>/dev/null)"
				[ -z "$iface" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"setGuestDefaultEnabled: iface required"}'
					exit 0
				}
				# jsonfilter boolean -> "true"/"false"; jshn expects 1/0 for boolean values.
				case "$enabled" in
					1|true|TRUE|True) enabled=1 ;;
					0|false|FALSE|False|"") enabled=0 ;;
					*) enabled=0 ;;
				esac
				json_init
				json_add_boolean enabled "$enabled"
				body="$(json_dump)"
				json_cleanup
				bplus_put_json "$body" "$BASE/api/rate_limit/guest_defaults/$(uripart "$iface")/enable"
				;;
			deleteGuestDefault)
				iface="${3:-}"
				[ -z "$iface" ] && { read -t 1 -r input || true; iface="$(echo "$input" | jsonfilter -e '$[0]')"; [ -z "$iface" ] && iface="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"; }
				bplus_delete "$BASE/api/rate_limit/guest_defaults/$(uripart "$iface")"
				;;
			getGuestWhitelist) bplus_get "$BASE/api/rate_limit/guest_whitelist" ;;
			addGuestWhitelist)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				[ -z "$js" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"addGuestWhitelist: empty body"}'
					exit 0
				}
				bplus_post_json "$js" "$BASE/api/rate_limit/guest_whitelist"
				;;
			removeGuestWhitelist)
				input=""
				read -r -t 5 input || true
				js="${3:-}"
				if [ -n "$input" ]; then
					js="$(bplus_unwrap_payload "$input")"
				elif [ -n "$js" ]; then
					js="$(bplus_unwrap_payload "$js")"
				fi
				[ -z "$js" ] && {
					printf '%s\n' '{"ok":false,"data":null,"error":"removeGuestWhitelist: empty body"}'
					exit 0
				}
				bplus_delete_json "$js" "$BASE/api/rate_limit/guest_whitelist"
				;;
			setDeviceHostname)
				# LuCI RPC 与 luci.bandix setHostname 一致：stdin 为 JSON 数组 [iface,mac,hostname] 或对象 {iface,mac,hostname}
				input=""
				read -r -t 5 input || true
				iface="${3:-}"; mac="${4:-}"; hn="${5:-}"
				if [ -n "$input" ]; then
					iobj="$(echo "$input" | jsonfilter -e '$.iface' 2>/dev/null)"
					mobj="$(echo "$input" | jsonfilter -e '$.mac' 2>/dev/null)"
					hobj="$(echo "$input" | jsonfilter -e '$.hostname' 2>/dev/null)"
					if [ -n "$mobj" ]; then
						iface="$iobj"; mac="$mobj"; hn="$hobj"
					else
						iface="$(echo "$input" | jsonfilter -e '$[0]' 2>/dev/null)"
						mac="$(echo "$input" | jsonfilter -e '$[1]' 2>/dev/null)"
						hn="$(echo "$input" | jsonfilter -e '$[2]' 2>/dev/null)"
					fi
				fi
				if [ -z "$iface" ] || [ -z "$mac" ] || [ -z "$hn" ]; then
					printf '%s\n' '{"ok":false,"data":"error","error":"setDeviceHostname: iface, mac and hostname required"}'
					exit 0
				fi
				json_init
				json_add_string iface "$iface"
				json_add_string mac "$mac"
				json_add_string hostname "$hn"
				js="$(json_dump)"
				json_cleanup
				bplus_put_json "$js" "$BASE/api/devices/hostname"
				;;
			getVersion)
				pkgv=""
				if command -v apk >/dev/null 2>&1; then
					apk_raw=$(apk list --installed "luci-app-bandix-plus" 2>/dev/null | awk '{print $1}')
					if [ -n "$apk_raw" ]; then
						# 移除前缀 "luci-app-bandix-plus-" 提取出真实版本号
						pkgv="${apk_raw#luci-app-bandix-plus-}"
					fi
				elif command -v opkg >/dev/null 2>&1; then
					pkgv=$(opkg status luci-app-bandix-plus 2>/dev/null | grep "^Version:" | cut -d' ' -f2)
				fi
				if [ -z "$pkgv" ]; then
					pkgv=$(grep -h "^Version:" /lib/apk/db/installed /usr/lib/info/luci-app-bandix-plus.control /usr/lib/opkg/info/bandix-plus.control 2>/dev/null | head -n 1 | cut -d' ' -f2)
				fi

				hb=$(bplus_get "$BASE/api/health")
				api_ok=""; echo "$hb" | grep -q '"ok":true' && api_ok=1
				json_init
				json_add_string "bandix_plus_pkg" "${pkgv:-unknown}"
				json_add_string "api_health_ok" "${api_ok:-0}"
				json_dump
				json_cleanup
				;;
			getStatus)
				# enabled: /etc/init.d/bandix-plus enabled exit code (0=enabled)
				enabled=0
				if [ -x /etc/init.d/bandix-plus ]; then
					/etc/init.d/bandix-plus enabled 2>/dev/null && enabled=1
				fi

				# running/pid: ask procd via ubus
				running=0
				pid=0
				svc_json="$(ubus call service list '{"name":"bandix-plus"}' 2>/dev/null)"
				if [ -n "$svc_json" ]; then
					pid="$(echo "$svc_json" | jsonfilter -e '$["bandix-plus"].instances["bandix-plus"].pid' 2>/dev/null)"
					case "$pid" in
						''|*[!0-9]*) pid=0 ;;
					esac
					[ "$pid" -gt 0 ] 2>/dev/null && running=1
				fi
				if [ "$running" -eq 0 ] && [ -f /var/run/bandix-plus.pid ]; then
					p="$(cat /var/run/bandix-plus.pid 2>/dev/null)"
					case "$p" in
						''|*[!0-9]*) ;;
						*)
							if [ -d "/proc/$p" ]; then
								running=1
								pid="$p"
							fi
							;;
					esac
				fi

				# uci enable_traffic flag (1 means user wants service running)
				enable_traffic="$(uci -q get bandix_plus.general.enable_traffic)"
				[ -z "$enable_traffic" ] && enable_traffic=0

				# api health probe
				hb=$(bplus_get "$BASE/api/health")
				api_ok=0
				echo "$hb" | grep -q '"ok":true' && api_ok=1

				# package version
				pkgv=""
				if command -v apk >/dev/null 2>&1; then
					apk_raw=$(apk list --installed "luci-app-bandix-plus" 2>/dev/null | awk '{print $1}')
					if [ -n "$apk_raw" ]; then
						pkgv="${apk_raw#luci-app-bandix-plus-}"
					fi
				elif command -v opkg >/dev/null 2>&1; then
					pkgv=$(opkg status luci-app-bandix-plus 2>/dev/null | grep "^Version:" | cut -d' ' -f2)
				fi
				if [ -z "$pkgv" ]; then
					pkgv=$(grep -h "^Version:" /lib/apk/db/installed /usr/lib/info/luci-app-bandix-plus.control /usr/lib/opkg/info/bandix-plus.control 2>/dev/null | head -n 1 | cut -d' ' -f2)
				fi

				json_init
				json_add_int    "enabled"         "$enabled"
				json_add_int    "running"         "$running"
				json_add_int    "pid"             "$pid"
				json_add_int    "enable_traffic"  "$enable_traffic"
				json_add_int    "api_health_ok"   "$api_ok"
				json_add_string "bandix_plus_pkg" "${pkgv:-unknown}"
				json_dump
				json_cleanup
				;;
			restartService)
				( sleep 1; /etc/init.d/bandix-plus restart ) >/dev/null 2>&1 &
				json_init; json_add_string ok "1"; json_dump; json_cleanup
				;;
		esac
		;;
esac
