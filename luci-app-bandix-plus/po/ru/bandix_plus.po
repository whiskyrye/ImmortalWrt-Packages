msgid "TC backend"
msgstr "Бэкенд TC"

msgid "Select TC attach backend."
msgstr "Выберите бэкенд подключения TC."

msgid ""
"Select TC attach backend. Recommendation: use auto by default; tcx is "
"preferred on kernel >= 6.6; netlink is safer on older kernels."
msgstr ""
"Выберите TC, чтобы смонтировать серверную часть. Рекомендация: используйте "
"авто по умолчанию; сначала используйте tcx для ядра >= 6.6; используйте "
"netlink для старых ядер, что более надежно."

msgid "TC netlink priority"
msgstr "Приоритет TC netlink"

msgid "Only used when backend is netlink. Range: 0..65535 (0 means default)."
msgstr ""
"Используется только при backend=netlink. Диапазон: 0..65535 (0 — значение по"
" умолчанию)."

msgid "Netlink priority"
msgstr "Приоритет сетевых ссылок"

msgid "TCX anchor program id"
msgstr "ID якорной программы TCX"

