#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1
PROG=/usr/bin/bandix-plus

service_triggers() {
	procd_add_reload_trigger "bandix-plus"
}

reload_service() {
	restart
}

append_iface() {
	local name="$1"
	[ -n "$name" ] && IFACES="$IFACES $name"
}

start_service() {
	local enable_traffic
	local tc_backend
	local tc_order
	local netlink_priority
	local tcx_anchor_ingress_id
	local tcx_anchor_egress_id
	local traffic_enable_storage
	local history_window_minutes
	local host
	local port
	local data_dir
	local log_level
	local IFACES=""

	config_load 'bandix_plus'
	config_get_bool enable_traffic 'general' 'enable_traffic' '0'
	config_get log_level 'general' 'log_level'
	config_get tc_backend 'general' 'tc_backend' 'auto'
	config_get tc_order 'general' 'tc_order' 'default'
	config_get netlink_priority 'general' 'netlink_priority'
	config_get tcx_anchor_ingress_id 'general' 'tcx_anchor_ingress_id'
	config_get tcx_anchor_egress_id 'general' 'tcx_anchor_egress_id'
	config_get_bool traffic_enable_storage 'general' 'traffic_enable_storage' '0'
	config_get history_window_minutes 'general' 'history_window_minutes' '10'
	config_get host 'general' 'host' '127.0.0.1'
	config_get port 'general' 'port' '8787'
	config_get data_dir 'general' 'data_dir' '/usr/share/bandix-plus'
	config_list_foreach 'general' 'iface' append_iface

	[ "$enable_traffic" -eq 1 ] || return 1
	[ -n "$IFACES" ] || {
		logger -t bandix-plus "no iface configured"
		return 1
	}
	case "$port" in
		''|*[!0-9]*)
			logger -t bandix-plus "invalid port: $port"
			return 1
		;;
	esac
	[ "$port" -ge 1 ] && [ "$port" -le 65535 ] || {
		logger -t bandix-plus "port out of range: $port"
		return 1
	}
	procd_open_instance bandix-plus
	procd_set_param command "$PROG"
	procd_append_param command --enable-traffic
	procd_append_param command --log-level "$log_level"
	procd_append_param command --tc-backend "$tc_backend"
	procd_append_param command --tc-order "$tc_order"
	[ -n "$netlink_priority" ] && [ "$netlink_priority" != "0" ] && procd_append_param command --netlink-priority "$netlink_priority"
	[ -n "$tcx_anchor_ingress_id" ] && procd_append_param command --tcx-anchor-ingress-id "$tcx_anchor_ingress_id"
	[ -n "$tcx_anchor_egress_id" ] && procd_append_param command --tcx-anchor-egress-id "$tcx_anchor_egress_id"
	[ "$traffic_enable_storage" -eq 1 ] && procd_append_param command --traffic_enable_storage
	procd_append_param command --history-window-minutes "$history_window_minutes"
	procd_append_param command --host "$host"
	procd_append_param command --port "$port"
	procd_append_param command --data-dir "$data_dir"

	local iface
	for iface in $IFACES; do
		procd_append_param command --iface "$iface"
	done

	procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-60} ${respawn_retry:-3}
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_set_param pidfile /var/run/bandix-plus.pid
	procd_close_instance
}
